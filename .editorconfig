# EditorConfig — keeps formatting consistent across editors and platforms.
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{py,pyi}]
indent_size = 4
# The repo uses double quotes (see pyproject.toml -> ruff quote-style = "double").

[*.{yml,yaml}]
indent_size = 2

[*.{json,toml}]
indent_size = 2

[*.md]
# Markdown needs trailing two spaces for hard line breaks.
trim_trailing_whitespace = false

[Makefile]
# Make requires literal tabs for recipe lines.
indent_style = tab
