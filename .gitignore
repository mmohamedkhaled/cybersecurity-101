# --------------------------------------------------------------------------
# Cybersecurity 101 — ignored files
# --------------------------------------------------------------------------
# This repo ships flat, runnable scripts and the committed sample output
# `ecb_pattern.png`, so that artifact is intentionally NOT ignored.

# ---- Python --------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# ---- Secrets / environment files -----------------------------------------
# Belt-and-suspenders: this repo uses no secrets, but never let local
# environment files or key material land in version control.
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx

# Packaging / builds (kept out — this repo is not installed as a package)
build/
dist/
wheels/
*.egg
*.egg-info
MANIFEST

# ---- Virtual environments -------------------------------------------------
.venv/
venv/
env/
ENV/

# ---- Tool caches ----------------------------------------------------------
.mypy_cache/
.ruff_cache/
.pytest_cache/
.typecheck_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover

# ---- Jupyter --------------------------------------------------------------
.ipynb_checkpoints/

# ---- Editors / IDEs -------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# ---- Operating systems ----------------------------------------------------
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini
